{
  "name": "barber-booking",
  "private": true,
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-unknown",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\" --ignore-unknown"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["unrs-resolver", "esbuild"]
  }
}
